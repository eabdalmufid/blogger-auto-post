# Blogger publish-by-email address (e.g. yourname.uniqueid@blogger.com)
# Dapatkan di: Blogger > Settings > Email > Posting using email
BLOGGER_EMAIL=

# Google Gemini API key
# Dapatkan di: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Pexels API key untuk gambar thumbnail (opsional, tapi disarankan)
# Dapatkan di: https://www.pexels.com/api/new/
PEXELS_API_KEY=

# Konfigurasi SMTP untuk mengirim email
# Contoh menggunakan Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=emailanda@gmail.com
SMTP_PASS=

# Catatan untuk Gmail:
# 1. Aktifkan 2-Step Verification di akun Google Anda
# 2. Buat App Password di: https://myaccount.google.com/apppasswords
# 3. Gunakan App Password tersebut sebagai SMTP_PASS

# Konfigurasi blog (opsional - sudah ada default)
BLOG_CATEGORIES=technology,lifestyle,health
BLOG_WORDS=1200
BLOG_PROMPT=

# Jadwal cron (default: setiap hari jam 07:00)
# Format: menit jam hari bulan hari-minggu
CRON_SCHEDULE=0 7 * * *
